# === Polarisor Public Repo — Universal .gitignore ===
# Copy this to each project being open-sourced

# Dependencies
node_modules/
.pnpm-store/
__pycache__/
*.pyc
.venv/
venv/

# Environment & Secrets
.env
.env.*
*.secret
*.key
*.pem
credentials*
tokens*
config.local.*

# Databases & Data
*.sqlite
*.db
data/
*.jsonl

# Internal Planning & Management
.planning/
.sotagent-outbox/
任务书/
_reports/
knowledge/crystals/

# Build Artifacts
dist/
build/
out/
*.tsbuildinfo

# IDE & OS
.DS_Store
Thumbs.db
.cursor/
.vscode/settings.json

# Logs
*.log
logs/

# Archives & Temp
.archived/
.clawbin/
tmp/
